<% content_for :title, "Attendance" %>

<section class="card attendance-visualization palette-<%= @color_profile %>">
  <h2>Attendance</h2>

  <%= form_with url: attendances_path, method: :get, local: true, class: "toolbar" do |f| %>
    <%= f.label :date, "Date" %>
    <%= f.date_field :date, value: @selected_date %>

    <%= f.label :player_id, "Player" %>
    <%= f.select :player_id, @players.collect { |p| [p.name, p.id] }, { include_blank: "(all)" }, selected: @selected_player&.id %>

    <%= f.label :view, "View" %>
    <%= f.select :view, [["Daily", "daily"], ["Weekly", "weekly"], ["Monthly", "monthly"], ["Calendar", "calendar"]], selected: @view_mode %>

    <%= f.label :color_profile, "Color profile" %>
    <%= f.select :color_profile,
                 [["Standard", "default"],
                  ["Red-Green Friendly", "red_green_safe"],
                  ["Blue-Yellow Friendly", "tritanopia_safe"],
                  ["High Contrast Monochrome", "monochrome"]],
                 selected: @color_profile %>
    <%= f.submit "Apply" %>
  <% end %>

  <% if @selected_player %>
    <div class="attendance-summary">
      <strong><%= @selected_player.name %> attendance for <%= @selected_date.strftime('%B %Y') %></strong>
      <div class="progress-container" title="Monthly attendance: <%= @percent_attended %>%">
        <div class="progress-fill" style="width: <%= @percent_attended %>%;" aria-label="Monthly attendance progress: <%= @percent_attended %>%"></div>
      </div>
      <p><%= @percent_attended %>% of days attended this month</p>
    </div>
  <% end %>

  <div class="heat-legend" aria-label="Attendance heatmap legend">
    <strong>Heatmap legend:</strong>
    <span class="legend-item">
      <span class="legend-swatch heat-0" aria-hidden="true"></span>
      <span>No attendance recorded</span>
    </span>
    <span class="legend-item">
      <span class="legend-swatch heat-1" aria-hidden="true"></span>
      <span>Attendance recorded</span>
    </span>
  </div>

  <% if @view_mode == "calendar" %>
    <% if @selected_player %>
      <table class="calendar">
        <thead>
          <tr>
            <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |day| %>
              <th><%= day %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% first = @selected_date.beginning_of_month.beginning_of_week(:monday) %>
          <% last = @selected_date.end_of_month.end_of_week(:sunday) %>
          <% (first..last).to_a.in_groups_of(7, nil) do |week| %>
            <tr>
              <% week.each do |day| %>
                <td class="<%= 'other-month' if day && day.month != @selected_date.month %>">
                  <% if day %>
                    <div class="day-number"><%= day.day %></div>
                    <% attendance = @calendar_attendances[day] %>
                    <% if attendance %>
                      <% if attendance.attended %>
                        <div class="status status-pill present" title="Present on <%= day %>" aria-label="Present on <%= day %>">
                          <span class="status-icon" aria-hidden="true">P</span>
                          <span class="status-text">Present</span>
                        </div>
                      <% else %>
                        <div class="status status-pill absent" title="Absent on <%= day %>" aria-label="Absent on <%= day %>">
                          <span class="status-icon" aria-hidden="true">A</span>
                          <span class="status-text">Absent</span>
                        </div>
                      <% end %>
                    <% else %>
                      <div class="status status-pill no-data" title="No attendance entry for <%= day %>" aria-label="No attendance entry for <%= day %>">
                        <span class="status-icon" aria-hidden="true">N</span>
                        <span class="status-text">No data</span>
                      </div>
                    <% end %>
                    <% if current_user.coach? %>
                      <%= button_to "Toggle", toggle_attendances_path(date: day, player_id: @selected_player.id), method: :patch,
                                    form: { style: "display: inline-block;" },
                                    class: "toggle-link",
                                    style: "font-size: 0.8em; padding: 2px 5px;" %>
                    <% end %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>Please select a player to view the calendar.</p>
    <% end %>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>Player</th>
          <th>Date</th>
          <th>Days</th>
          <th>Attended</th>
          <th>Source</th>
        </tr>
      </thead>
      <tbody>
        <% @attendances.each do |attendance| %>
          <% is_present = attendance.attended %>
          <tr class="heat-<%= attendance.heat_level %>" title="<%= is_present ? "Present" : "Absent" %> on <%= attendance.date %>">
            <td><%= attendance.player.name %></td>
            <td><%= attendance.date %></td>
            <td><%= attendance.days_attended %></td>
            <td style="display: flex; align-items: center; gap: 10px;">
              <span class="status-pill <%= is_present ? "present" : "absent" %>" title="<%= is_present ? "Present" : "Absent" %> status" aria-label="<%= is_present ? "Present" : "Absent" %> status">
                <span class="status-icon" aria-hidden="true"><%= is_present ? "P" : "A" %></span>
                <span><%= is_present ? "Present" : "Absent" %></span>
              </span>

              <% if current_user.coach? %>
                <%= button_to "Swap",
                              toggle_attendance_path(attendance, color_profile: @color_profile, view: @view_mode),
                              method: :patch,
                              form: { style: "display: inline-block; margin: 0;" },
                              style: "font-size: 0.8em; padding: 2px 5px;" %>
              <% end %>
            </td>
            <td><%= attendance.source %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>

<section class="card">
  <header class="card-header">
    <h2>Imported Practice Rosters</h2>
    <p>Latest participant lists scraped from the Sport Clubs event pages.</p>
  </header>

  <% if @recent_recsports_events.any? %>
    <div class="workout-history">
      <% @recent_recsports_events.each do |event| %>
        <article class="history-item" style="display: block; margin-bottom: 16px;">
          <strong><%= event.title %></strong>
          <div>
            <%= [event.starts_at&.strftime("%b %d, %Y %I:%M%P"), event.venue].compact.join(" at ") %>
          </div>
          <div>
            <%= pluralize(event.participants.size, "participant") %>
          </div>
          <div>
            <%= event.participants.map { |participant| participant.user.name }.join(", ") %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">No imported Sport Clubs practice data yet.</p>
  <% end %>
</section>

<% unless current_user.coach? %>
  <section class="card workout-card">
    <header class="card-header">
      <h2>Log a Workout</h2>
      <p>Submit your workout date and a link to your proof.</p>
    </header>

    <%= form_with model: WorkoutCheckin.new, url: workout_checkins_path, local: true, class: "workout-form" do |f| %>
      <div class="form-group">
        <%= f.label :workout_date, "Date Completed", class: "form-label" %>
        <%= f.date_field :workout_date, required: true, max: Date.today, class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :proof_url, "Proof of Workout (URL)", class: "form-label" %>
        <%= f.url_field :proof_url, placeholder: "https://...", class: "form-control" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Save Workout", class: "btn-primary" %>
      </div>
    <% end %>

    <div class="workout-history">
      <div class="month-navigation" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
        
        <%= link_to "← Previous", attendances_path(workout_month: @workout_month.last_month.strftime("%Y-%m-%d")), class: "btn-secondary", style: "text-decoration: none;" %>
        
        <h3 style="margin: 0;"><%= @workout_month.strftime("%B %Y") %></h3>
        
        <% if @workout_month.beginning_of_month < Date.today.beginning_of_month %>
          <%= link_to "Next →", attendances_path(workout_month: @workout_month.next_month.strftime("%Y-%m-%d")), class: "btn-secondary", style: "text-decoration: none;" %>
        <% else %>
          <span class="text-muted" style="opacity: 0.5;">Next →</span>
        <% end %>
      </div>

      <% if @workout_checkins.present? %>
        <ul class="history-list">
          <% @workout_checkins.each do |checkin| %>
            <li class="history-item">
              <strong><%= checkin.workout_date.strftime("%b %d, %Y") %></strong> 
              
              <% if checkin.proof_url.present? %>
                - <%= link_to "View Proof", checkin.proof_url, target: "_blank", rel: "noreferrer", class: "proof-link" %>
              <% else %>
                - <span class="text-muted">No proof provided</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-state">No workouts logged for <%= @workout_month.strftime("%B") %>.</p>
      <% end %>
    </div>
  </section>
<% end %>
