<% content_for :title, "Attendance" %>

<section class="card attendance-visualization palette-<%= @color_profile %>">
  <h2>Attendance</h2>

 <%
    # Dynamically set the input type and formatting based on the current view
    input_type = case @view_mode
                 when "monthly", "calendar" then "month"
                 when "weekly" then "week"
                 else "date"
                 end

    formatted_date = case @view_mode
                     when "monthly", "calendar" then @selected_date.strftime("%Y-%m")
                     when "weekly" then @selected_date.strftime("%Y-W%V")
                     else @selected_date.strftime("%Y-%m-%d")
                     end
  %>

  <%= form_with url: attendances_path, method: :get, local: true, class: "toolbar" do |f| %>
    <%= f.label :date, "Date" %>
    <input type="<%= input_type %>" name="date" id="dynamic-date-input" value="<%= formatted_date %>">

    <%= f.label :player_id, "Player" %>
    <%= f.select :player_id, 
                 options_for_select(@players.map { |p| [p.name, p.id] }, @selected_player&.id), 
                 { include_blank: "(all)" } %>

    <%= f.label :view, "View" %>
    <%= f.select :view, 
                 options_for_select([["Daily", "daily"], ["Weekly", "weekly"], ["Monthly", "monthly"], ["Calendar", "calendar"]], @view_mode), 
                 {}, { id: "view-mode-select" } %>

    <%= f.label :color_profile, "Color profile" %>
    <%= f.select :color_profile, 
                 options_for_select([["Standard", "default"], ["Red-Green Friendly", "red_green_safe"], ["Blue-Yellow Friendly", "tritanopia_safe"], ["High Contrast Monochrome", "monochrome"]], @color_profile) %>
                 
  <% end %>

  <% if @selected_player %>
    <div class="attendance-summary">
      <strong><%= @selected_player.name %> attendance for <%= @selected_date.strftime('%B %Y') %></strong>
      <div class="progress-container" title="Monthly attendance: <%= @percent_attended %>%">
        <div class="progress-fill" style="width: <%= @percent_attended %>%;" aria-label="Monthly attendance progress: <%= @percent_attended %>%"></div>
      </div>
      <p><%= @percent_attended %>% of days attended this month</p>
    </div>
  <% end %>

  <div class="heat-legend" aria-label="Attendance heatmap legend">
    <strong>Heatmap legend:</strong>
    <span class="legend-item"><span class="legend-swatch heat-0" aria-hidden="true"></span><span>0% attendance</span></span>
    <span class="legend-item"><span class="legend-swatch heat-1" aria-hidden="true"></span><span>1-24% attendance</span></span>
    <span class="legend-item"><span class="legend-swatch heat-2" aria-hidden="true"></span><span>25-49% attendance</span></span>
    <span class="legend-item"><span class="legend-swatch heat-3" aria-hidden="true"></span><span>50-74% attendance</span></span>
    <span class="legend-item"><span class="legend-swatch heat-4" aria-hidden="true"></span><span>75-100% attendance</span></span>
  </div>

  <% if @view_mode == "calendar" %>
    <% if @selected_player %>
      <table class="calendar">
        <thead>
          <tr>
            <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |day| %>
              <th><%= day %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% first = @selected_date.beginning_of_month.beginning_of_week(:monday) %>
          <% last = @selected_date.end_of_month.end_of_week(:sunday) %>
          <% (first..last).to_a.in_groups_of(7, nil) do |week| %>
            <tr>
              <% week.each do |day| %>
                <td class="<%= 'other-month' if day && day.month != @selected_date.month %>">
                  <% if day %>
                    <div class="day-number"><%= day.day %></div>
                    <% attendance = @calendar_attendances[day] %>
                    <% if attendance %>
                      <% if attendance.attended %>
                        <div class="status status-pill present" title="Present on <%= day %>" aria-label="Present on <%= day %>">
                          <span class="status-icon" aria-hidden="true">P</span>
                          <span class="status-text">Present</span>
                        </div>
                      <% else %>
                        <div class="status status-pill absent" title="Absent on <%= day %>" aria-label="Absent on <%= day %>">
                          <span class="status-icon" aria-hidden="true">A</span>
                          <span class="status-text">Absent</span>
                        </div>
                      <% end %>
                    <% else %>
                      <div class="status status-pill no-data" title="No attendance entry for <%= day %>" aria-label="No attendance entry for <%= day %>">
                        <span class="status-icon" aria-hidden="true">N</span>
                        <span class="status-text">No data</span>
                      </div>
                    <% end %>
                    <% if current_user.coach? %>
                      <%= button_to "Toggle", toggle_attendances_path(date: day, player_id: @selected_player.id), method: :patch,
                                    form: { style: "display: inline-block;" },
                                    class: "toggle-link",
                                    style: "font-size: 0.8em; padding: 2px 5px;" %>
                    <% end %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <h3>Team Attendance Calendar - <%= @selected_date.strftime("%B %Y") %></h3>
      <p>Shows number of players who attended each day</p>
      <table class="calendar all-players">
        <thead>
          <tr>
            <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |day| %>
              <th><%= day %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% first = @selected_date.beginning_of_month.beginning_of_week(:monday) %>
          <% last = @selected_date.end_of_month.end_of_week(:sunday) %>
          <% (first..last).to_a.in_groups_of(7, nil) do |week| %>
            <tr>
              <% week.each do |day| %>
                <% day_class = "" %>
                <% if day %>
                  <% count = @attendance_counts_by_day[day] || 0 %>
                  <% pct = @players.any? ? ((count.to_f / @players.count) * 100).round : 0 %>
                  <% day_class = if pct == 0
                                   "heat-0"
                                 elsif pct < 25
                                   "heat-1"
                                 elsif pct < 50
                                   "heat-2"
                                 elsif pct < 75
                                   "heat-3"
                                 else
                                   "heat-4"
                                 end %>
                <% else %>
                  <% count = 0 %>
                <% end %>

                <td class="<%= ['other-month', day_class].compact.join(' ') if day %>">
                  <% if day %>
                    <div class="day-number"><%= day.day %></div>
                    <div class="attendance-count">
                      <strong><%= count %></strong>
                      <% if count > 0 %>
                        <small><%= count == 1 ? "player" : "players" %></small>
                      <% else %>
                        <small>–</small>
                      <% end %>
                    </div>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  <% else %>
    <!-- Summary table view for daily, weekly, and monthly modes -->
    <table>
      <thead>
        <tr>
          <th>Player</th>
          <th>Days Attended</th>
          <th>Total Possible Days</th>
          <th>Attendance %</th>
          <th>Workout Complete (2/wk)</th>
        </tr>
      </thead>
      <tbody>
        <% total_attended = 0 %>
        <% total_possible = 0 %>
        <% @attendance_summary.each do |summary| %>
          <% total_attended += summary[:total_days_attended] %>
          <% total_possible += summary[:total_possible_days] %>
          <% heat_class = case summary[:percent_attended]
                        when 0 then "heat-0"
                        when 1..24 then "heat-1"
                        when 25..49 then "heat-2"
                        when 50..74 then "heat-3"
                        else "heat-4"
                        end %>
          <tr class="<%= heat_class %>">
            <td><%= summary[:player].name %></td>
            <td><%= summary[:total_days_attended] %></td>
            <td><%= summary[:total_possible_days] %></td>
            <td><%= summary[:percent_attended] %>%</td>
            <td>
              <% week_start = @selected_date.beginning_of_week(:monday) %>
              <% weekly = WeeklyWorkout.find_by(player: summary[:player], week_start_date: week_start) %>
              <% completed = weekly&.complete || false %>
              <% if current_user.coach? %>
                <%= form_with url: toggle_workout_complete_attendances_path, method: :post, local: true, style: 'display:inline' do |f| %>
                  <%= hidden_field_tag :player_id, summary[:player].id %>
                  <%= hidden_field_tag :week_start, week_start %>
                  <%= check_box_tag 'complete', '1', completed, onchange: 'this.form.submit();' %>
                <% end %>
              <% else %>
                <%= completed ? '✅' : '❌' %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr style="font-weight: bold; border-top: 2px solid #333;">
          <td>TOTAL</td>
          <td><%= total_attended %></td>
          <td><%= total_possible %></td>
          <td><%= total_possible > 0 ? ((total_attended.to_f / total_possible) * 100).round(1) : 0.0 %>%</td>
        </tr>
      </tfoot>
    </table>
  <% end %>
</section>

<!-- THE SCRAPING SECTION -->
<section class="card">
  <header class="card-header">
    <h2>Imported Practice Rosters</h2>
    <p>Latest participant lists scraped from the Sport Clubs event pages.</p>
  </header>

  <% if @recent_recsports_events.any? %>
    <div class="workout-history">
      <% @recent_recsports_events.each do |event| %>
        <article class="history-item" style="display: block; margin-bottom: 16px;">
          <strong><%= event.title %></strong>
          <div>
            <%= [event.starts_at&.strftime("%b %d, %Y %I:%M%P"), event.venue].compact.join(" at ") %>
          </div>
          <div>
            <%= pluralize(event.participants.size, "participant") %>
          </div>
          <div>
            <%= event.participants.map { |participant| participant.user.name }.join(", ") %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">No imported Sport Clubs practice data yet.</p>
  <% end %>
</section>

<!-- SPECIFIC PLAYER IS SELECTED FROM THE DROPDOWN -->
<% if @selected_player %>
