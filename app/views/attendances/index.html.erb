                      <%= button_to "Delete", workout_checkin_path(checkin), method: :delete, data: { turbo_confirm: "Delete this workout?" }, form: { style: "margin-left: auto;" }, style: "color: #d9534f; background: none; border: none; cursor: pointer; text-decoration: underline; font-size: 0.85em;" %>
