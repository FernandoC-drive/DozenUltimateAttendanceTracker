          <%= f.label :proof_url, "Proof of Workout (URL)", class: "form-label" %>
          <%= f.url_field :proof_url, placeholder: "https://...", class: "form-control" %>
        </div>

        <div class="form-group" style="margin-top: 10px;">
          <%= f.label :proof_image, "Or Upload an Image", class: "form-label" %>
          <%= f.file_field :proof_image, class: "form-control", id: "workout-file-input", accept: "image/*" %>
          <p id="size-error" class="error-text" style="display: none; color: #d9534f; margin-top: 5px;">Error: File too large (max 5MB).</p>
        </div>

        <div id="preview-container" style="display: none; margin-top: 10px; padding: 10px; border: 1px dashed #ccc; border-radius: 4px;">
          <img id="image-preview" src="#" alt="Selected preview" style="max-height: 150px; max-width: 100%; display: block; margin-bottom: 10px; border-radius: 4px;">
          <button type="button" id="clear-image-btn" style="background: none; border: 1px solid #d9534f; color: #d9534f; padding: 4px 8px; border-radius: 4px; cursor: pointer; font-size: 0.85em;">Remove Selected Image</button>
        </div>

        <div class="form-actions">
          <%= f.submit "Save Workout", class: "btn-primary", id: "workout-tracker-button" %>
        </div>
      <% end %>

      <div class="workout-history">
        <div class="month-navigation" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
          <%= link_to "← Previous", attendances_path(workout_month: @workout_month.last_month.strftime("%Y-%m-%d")), class: "btn-secondary", style: "text-decoration: none;" %>
          <h3 style="margin: 0;"><%= @workout_month.strftime("%B %Y") %></h3>
          <% if @workout_month.beginning_of_month < Date.today.beginning_of_month %>
            <%= link_to "Next →", attendances_path(workout_month: @workout_month.next_month.strftime("%Y-%m-%d")), class: "btn-secondary", style: "text-decoration: none;" %>
          <% else %>
            <span class="text-muted" style="opacity: 0.5;">Next →</span>
          <% end %>
        </div>

        <% if @workout_checkins.present? %>
          <div class="history-groups" style="display: flex; flex-direction: column; gap: 20px;">
            
            <!-- Group check-ins by their Monday, sort newest week first -->
            <% @workout_checkins.group_by { |c| c.workout_date.beginning_of_week(:monday) }.sort.reverse.each do |week_start, checkins| %>
              <div class="week-group">
                <h4 style="margin: 0 0 10px 0; border-bottom: 2px solid #eee; padding-bottom: 5px;">
                  Week of <%= week_start.strftime("%b %d") %> 
                  <span style="font-size: 0.8em; color: #888; font-weight: normal;">(Mon - Sun)</span>
                </h4>
                
                <ul class="history-list" style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px;">
                  <% checkins.each do |checkin| %>
                    <li class="history-item" style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap; padding: 8px; background: #f9f9f9; border: 1px solid #eee; border-radius: 6px;">
                      <strong><%= checkin.workout_date.strftime("%a, %b %d") %></strong> 
                      
                      <% if checkin.proof_image.attached? %>
                        <%= image_tag checkin.proof_image, style: "width: 50px; height: 50px; object-fit: cover; border-radius: 4px; border: 1px solid #ccc;" %>
                        <%= link_to "(View Full)", url_for(checkin.proof_image), target: "_blank", rel: "noreferrer", class: "proof-link", style: "font-size: 0.85em;" %>
                      <% elsif checkin.proof_url.present? %>
                        - <%= link_to "View Proof Link", checkin.proof_url, target: "_blank", rel: "noreferrer", class: "proof-link" %>
