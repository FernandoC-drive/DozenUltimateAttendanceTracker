<div id="<%= dom_id attendance_record %>">
  <p>
    <strong>Member:</strong>
    <%= attendance_record.member_id %>
  </p>

  <p>
    <strong>Date:</strong>
    <%= attendance_record.date %>
  </p>

  <p>
    <strong>Is present:</strong>
    <%= attendance_record.is_present %>
    <% if current_user.coach == true %>
      <%= button_to "Toggle", toggle_attendance_record_path(attendance_record), method: :patch, form: { style: "display: inline-block; margin-left: 10px;" }, style: "font-size: 0.8em; padding: 2px 5px;" %>
    <% end %>
  </p>

</div>
