<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "D Uattendandance" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <style>
      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 20px;
        background-color: #ffffff;
        border-bottom: 1px solid #e2e8f0;
      }
      .nav-container {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .btn-base {
        padding: 6px 14px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
      }
      .btn-nav {
        background-color: #f1f5f9;
        color: #334155;
      }
      .btn-nav:hover { background-color: #e2e8f0; }
      
      .btn-mode {
        background-color: #ffffff;
        border-color: #cbd5e1;
        color: #475569;
      }
      .btn-mode:hover { background-color: #f8fafc; border-color: #94a3b8; }
      
      .btn-danger {
        background-color: #ffffff;
        border-color: #fecaca;
        color: #ef4444;
      }
      .btn-danger:hover { background-color: #fef2f2; border-color: #fca5a5; }
      
      .pin-form {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #f8fafc;
        padding: 4px 6px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
      }
      .pin-input {
        border: 1px solid #cbd5e1;
        border-radius: 4px;
        padding: 4px 8px;
        width: 100px;
        font-size: 14px;
      }
      .pin-submit {
        background: #3b82f6;
        color: white;
        border: none;
        border-radius: 4px;
        padding: 5px 12px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
      }
      .pin-submit:hover { background: #2563eb; }
      
      .inline-form { margin: 0; display: flex; }
    </style>
  </head>

  <body>
    <header class="site-header">
      <h1 style="margin: 0; font-size: 1.5rem; color: #0f172a;">Dozen Ultimate Attendance Dashboard</h1>
      
      <% if current_user %>
        <nav class="nav-container">
          <%= link_to "Dashboard", root_path, class: "btn-base btn-nav" %>
          
          <% if current_user.coach? %>
            <%= link_to "Admin Settings", admin_attendances_path, class: "btn-base btn-nav" %>
            <%= link_to "RecSports Sync", admin_recsports_path, class: "btn-base btn-nav" %>
            <%= button_to "View as Player", toggle_coach_path, method: :delete, form_class: "inline-form", class: "btn-base btn-mode" %>
          <% else %>
            <%= form_with url: toggle_coach_path, method: :post, local: true, class: "pin-form inline-form" do |f| %>
              <%= f.password_field :password, placeholder: "Coach PIN", class: "pin-input" %>
              <%= f.submit "Enter", class: "pin-submit" %>
            <% end %>
          <% end %>

          <%= button_to "Sign out", session_path, method: :delete, data: { turbo: false }, form_class: "inline-form", class: "btn-base btn-danger" %>
        </nav>
      <% end %>
    </header>

    <% flash.each do |key, value| %>
      <p class="flash <%= key %>"><%= value %></p>
    <% end %>

    <main class="page-content">
      <%= yield %>
    </main>
  </body>
</html>
